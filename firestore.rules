rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity Validations
    function isValidUser(data, isCreate) {
      let hasRequired = isCreate ? data.keys().hasAll(['email', 'memory', 'createdAt', 'updatedAt']) && data.keys().size() == 4 : true;
      let typesOk = (
        data.email is string && data.email.size() <= 256 &&
        data.memory is list && data.memory.size() <= 100 &&
        (data.memory.size() == 0 || data.memory[0] is string) &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp
      );
      return hasRequired && typesOk;
    }
    
    function isValidWardrobeItem(data, isCreate) {
      let isPartialUpdate = !isCreate;
      let hasRequired = isCreate ? data.keys().hasAll(['image', 'category', 'silhouette', 'name', 'color', 'hexColor', 'material', 'pattern', 'style', 'season', 'description', 'wearCount', 'createdAt', 'updatedAt']) : true;
      let countOk = !isCreate || data.keys().size() == 14;
      
      let typesOk = (
        (!('image' in data) || (data.image is string && data.image.size() <= 1048576)) && // Max 1MB
        (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
        (!('silhouette' in data) || (data.silhouette is string && data.silhouette.size() <= 100)) &&
        (!('name' in data) || (data.name is string && data.name.size() <= 200)) &&
        (!('color' in data) || (data.color is string && data.color.size() <= 50)) &&
        (!('hexColor' in data) || (data.hexColor is string && data.hexColor.size() <= 10)) &&
        (!('material' in data) || (data.material is string && data.material.size() <= 100)) &&
        (!('pattern' in data) || (data.pattern is string && data.pattern.size() <= 100)) &&
        (!('style' in data) || (data.style is string && data.style.size() <= 100)) &&
        (!('season' in data) || (data.season is string && data.season.size() <= 50)) &&
        (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
        (!('wearCount' in data) || (data.wearCount is number && data.wearCount >= 0)) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp)
      );
      
      return hasRequired && countOk && typesOk;
    }

    function isValidChatMessage(data, isCreate) {
      let hasRequired = isCreate ? data.keys().hasAll(['role', 'text', 'timestamp']) : true;
      // Allow for optional itemIds and isLogged fields
      let countOk = !isCreate || (data.keys().size() >= 3 && data.keys().size() <= 6);
      let typesOk = (
        (!('role' in data) || (data.role is string && data.role.size() <= 20)) &&
        (!('text' in data) || (data.text is string && data.text.size() <= 5000)) &&
        (!('itemIds' in data) || (data.itemIds is list && data.itemIds.size() <= 20)) &&
        (!('isLogged' in data) || data.isLogged is bool) &&
        (!('timestamp' in data) || data.timestamp is timestamp) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp)
      );
      return hasRequired && countOk && typesOk;
    }

    function isValidSessionMetadata(data, isCreate) {
      let hasRequired = isCreate ? data.keys().hasAll(['title', 'lastMessage', 'createdAt', 'updatedAt']) : true;
      let countOk = !isCreate || (data.keys().size() >= 4 && data.keys().size() <= 5);
      let typesOk = (
        (!('title' in data) || (data.title is string && data.title.size() <= 100)) &&
        (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 5000)) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp)
      );
      return hasRequired && countOk && typesOk;
    }

    function isValidEvent(data, isCreate) {
      let hasRequired = isCreate ? data.keys().hasAll(['title', 'date', 'type', 'outfitItemIds', 'createdAt', 'updatedAt']) : true;
      let countOk = !isCreate || (data.keys().size() >= 6 && data.keys().size() <= 11);
      
      let typesOk = (
        (!('title' in data) || (data.title is string && data.title.size() <= 200)) &&
        (!('date' in data) || (data.date is string && data.date.size() <= 20)) &&
        (!('time' in data) || (data.time is string && data.time.size() <= 20)) &&
        (!('type' in data) || (data.type is string && data.type.size() <= 20)) &&
        (!('location' in data) || (data.location is string && data.location.size() <= 200)) &&
        (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
        (!('aiReasoning' in data) || (data.aiReasoning is string && data.aiReasoning.size() <= 3000)) &&
        (!('thread' in data) || (data.thread is list && data.thread.size() <= 100)) &&
        (!('outfitItemIds' in data) || (data.outfitItemIds is list && data.outfitItemIds.size() <= 50)) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('updatedAt' in data) || data.updatedAt is timestamp)
      );
      
      return hasRequired && countOk && typesOk;
    }

    // Rules
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false; 
      allow delete: if false; 
      allow create: if isOwner(userId)
                    && isValidId(userId)
                    && isVerified()
                    && isValidUser(incoming(), true)
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time
                    && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId)
                    && isValidId(userId)
                    && isVerified()
                    && isValidUser(incoming(), false)
                    && incoming().updatedAt == request.time
                    && incoming().createdAt == existing().createdAt
                    && incoming().email == existing().email
                    && incoming().diff(existing()).affectedKeys().hasOnly(['memory', 'updatedAt']);

      match /wardrobe/{itemId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && isValidId(itemId);
        allow create: if isOwner(userId)
                      && isVerified()
                      && isValidId(itemId)
                      && isValidWardrobeItem(incoming(), true)
                      && incoming().createdAt == request.time
                      && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
                      && isVerified()
                      && isValidId(itemId)
                      && isValidWardrobeItem(incoming(), false)
                      && incoming().updatedAt == request.time
                      && incoming().createdAt == existing().createdAt
                      && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'color', 'hexColor', 'style', 'season', 'wearCount', 'description', 'updatedAt', 'image', 'silhouette', 'material', 'pattern']);
      }

      match /sessions/{sessionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
                      && isVerified()
                      && isValidId(sessionId)
                      && isValidSessionMetadata(incoming(), true)
                      && incoming().createdAt == request.time
                      && incoming().updatedAt == request.time;
        allow update: if isOwner(userId) 
                      && isVerified()
                      && isValidId(sessionId)
                      && isValidSessionMetadata(incoming(), false)
                      && incoming().updatedAt == request.time
                      && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'title']);
        allow delete: if isOwner(userId) && isValidId(sessionId);
        
        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) 
                        && isVerified()
                        && isValidId(messageId)
                        && isValidChatMessage(incoming(), true)
                        && incoming().timestamp == request.time;
          allow update: if isOwner(userId) 
                        && isVerified()
                        && isValidId(messageId)
                        && isValidChatMessage(incoming(), false)
                        && incoming().updatedAt == request.time
                        && incoming().diff(existing()).affectedKeys().hasOnly(['isLogged', 'updatedAt']);
        }
      }

      match /chats/{messageId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && isValidId(messageId);
        allow create: if isOwner(userId)
                      && isVerified()
                      && isValidId(messageId)
                      && isValidChatMessage(incoming(), true);
        allow update: if isOwner(userId)
                      && isVerified()
                      && isValidId(messageId)
                      && isValidChatMessage(incoming(), false)
                      && incoming().diff(existing()).affectedKeys().hasOnly(['isLogged', 'updatedAt']);
      }
      match /events/{eventId} {
        allow read: if isOwner(userId);
        allow delete: if isOwner(userId) && isValidId(eventId);
        allow create: if isOwner(userId)
                      && isVerified()
                      && isValidId(eventId)
                      && isValidEvent(incoming(), true)
                      && incoming().createdAt == request.time
                      && incoming().updatedAt == request.time;
        allow update: if isOwner(userId)
                      && isVerified()
                      && isValidId(eventId)
                      && isValidEvent(incoming(), false)
                      && incoming().updatedAt == request.time
                      && incoming().createdAt == existing().createdAt
                      && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'time', 'type', 'location', 'description', 'aiReasoning', 'thread', 'outfitItemIds', 'updatedAt']);
      }
    }
  }
}
