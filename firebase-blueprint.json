{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing style memory.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "memory": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of learned style facts and preferences."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "memory", "createdAt", "updatedAt"]
    },
    "WardrobeItem": {
      "title": "WardrobeItem",
      "description": "A single clothing item.",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "category": { "type": "string" },
        "silhouette": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "hexColor": { "type": "string" },
        "material": { "type": "string" },
        "pattern": { "type": "string" },
        "style": { "type": "string" },
        "season": { "type": "string" },
        "description": { "type": "string" },
        "wearCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["image", "category", "silhouette", "name", "color", "hexColor", "material", "pattern", "style", "season", "wearCount", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "text": { "type": "string" },
        "itemIds": { "type": "array", "items": { "type": "string" } },
        "isLogged": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat conversation metadata.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "lastMessage", "createdAt", "updatedAt"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "A calendar event with associated outfits.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "aiReasoning": { "type": "string" },
        "thread": { "type": "array", "items": { "type": "object" } },
        "outfitItemIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "type", "outfitItemIds", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile with style memory."
    },
    "/users/{userId}/wardrobe/{itemId}": {
      "schema": { "$ref": "#/entities/WardrobeItem" },
      "description": "User's wardrobe items."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "User's chat sessions."
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages within a chat session."
    },
    "/users/{userId}/chats/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Legacy chat history."
    },
    "/users/{userId}/events/{eventId}": {
      "schema": { "$ref": "#/entities/CalendarEvent" },
      "description": "User's calendar events and assigned outfits."
    }
  }
}
